---
interface Props {
  dayStreak: number;
  totalBriefs: number;
  since: string;
}

const { dayStreak, totalBriefs, since } = Astro.props;
---

<div class="flex items-center justify-center gap-0 rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] overflow-hidden">
  <!-- Day Streak -->
  <div class="flex-1 flex flex-col items-center py-5 px-6">
    <span class="font-[var(--font-heading)] text-3xl font-bold text-[var(--color-text)] tracking-tight" style="font-family: 'Playfair Display', serif;">
      {dayStreak}
    </span>
    <span class="text-xs uppercase tracking-widest text-[var(--color-text-muted)] mt-1">
      Day Streak
    </span>
  </div>

  <!-- Divider -->
  <div class="w-px h-12 bg-[var(--color-border)]"></div>

  <!-- Total Briefs -->
  <div class="flex-1 flex flex-col items-center py-5 px-6">
    <span class="font-[var(--font-heading)] text-3xl font-bold text-[var(--color-text)] tracking-tight" style="font-family: 'Playfair Display', serif;">
      {totalBriefs}
    </span>
    <span class="text-xs uppercase tracking-widest text-[var(--color-text-muted)] mt-1">
      Total Briefs
    </span>
  </div>

  <!-- Divider -->
  <div class="w-px h-12 bg-[var(--color-border)]"></div>

  <!-- Since -->
  <div class="flex-1 flex flex-col items-center py-5 px-6">
    <span class="font-[var(--font-heading)] text-xl font-bold text-[var(--color-text)] tracking-tight" style="font-family: 'Playfair Display', serif;">
      {since}
    </span>
    <span class="text-xs uppercase tracking-widest text-[var(--color-text-muted)] mt-1">
      Running Since
    </span>
  </div>
</div>
