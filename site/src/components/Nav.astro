---
import { getBase } from "../lib/paths";

const base = getBase();
const currentPath = Astro.url.pathname;

/** Navigation links */
const links = [
  { href: base, label: "Home" },
  { href: `${base}archive/`, label: "Archive" },
  { href: `${base}about/`, label: "About" },
];

function isActive(linkHref: string): boolean {
  const normalized = linkHref.replace(/\/$/, "");
  const currentNormalized = currentPath.replace(/\/$/, "");
  if (normalized === base.replace(/\/$/, "")) {
    return currentNormalized === normalized;
  }
  return currentNormalized.startsWith(normalized);
}
---

<nav class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/80 backdrop-blur-xl">
  <div class="mx-auto max-w-3xl px-6">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a
        href={base}
        class="flex items-center gap-2.5 text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors duration-200"
      >
        <span class="text-xl" role="img" aria-label="scales of justice">&#x2696;&#xFE0F;</span>
        <span class="text-lg font-semibold tracking-tight" style="font-family: 'Playfair Display', serif;">
          Lawful AI
        </span>
      </a>

      <!-- Center links -->
      <div class="hidden sm:flex items-center gap-1">
        {links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "px-3.5 py-2 rounded-lg text-sm font-medium transition-all duration-200",
              isActive(link.href)
                ? "text-[var(--color-accent)] bg-[var(--color-accent)]/10"
                : "text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)]",
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Right icons -->
      <div class="flex items-center gap-2">
        <!-- RSS -->
        <a
          href={`${base}feed.xml`}
          class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-gold)] hover:bg-[var(--color-surface)] transition-all duration-200"
          title="RSS Feed"
        >
          <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z" />
          </svg>
        </a>

        <!-- GitHub -->
        <a
          href="https://github.com/laugustyniak/lawful-ai"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)] transition-all duration-200"
          title="GitHub"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button
          id="mobile-menu-btn"
          class="sm:hidden inline-flex items-center justify-center w-9 h-9 rounded-lg text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)] transition-all duration-200"
          aria-label="Toggle menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu (hidden by default) -->
    <div id="mobile-menu" class="sm:hidden hidden pb-4 border-t border-[var(--color-border)] mt-0 pt-3">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={[
            "block px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200",
            isActive(link.href)
              ? "text-[var(--color-accent)] bg-[var(--color-accent)]/10"
              : "text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)]",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
