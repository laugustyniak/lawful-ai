---
import { getBase } from "../lib/paths";

const base = getBase();
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] mt-20">
  <div class="mx-auto max-w-3xl px-6 py-12">
    <!-- Top section -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mb-8">
      <!-- Brand -->
      <div class="flex items-center gap-2.5">
        <span class="text-lg" role="img" aria-label="scales of justice">&#x2696;&#xFE0F;</span>
        <span class="text-base font-semibold text-[var(--color-text)]" style="font-family: 'Playfair Display', serif;">
          Lawful AI
        </span>
      </div>

      <!-- Links -->
      <div class="flex items-center gap-6 text-sm">
        <a href={base} class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-200">
          Home
        </a>
        <a href={`${base}archive/`} class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-200">
          Archive
        </a>
        <a href={`${base}about/`} class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-200">
          About
        </a>
        <a href={`${base}feed.xml`} class="text-[var(--color-text-muted)] hover:text-[var(--color-gold)] transition-colors duration-200">
          RSS
        </a>
        <a href="https://github.com/laugustyniak/lawful-ai" target="_blank" rel="noopener noreferrer" class="text-[var(--color-text-muted)] hover:text-[var(--color-text)] transition-colors duration-200">
          GitHub
        </a>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-[var(--color-border)] pt-6">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-[var(--color-text-muted)]">
        <p>
          Curated by <a href="https://augustyniak.ai" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] transition-colors">@laugustyniak</a>
        </p>
        <p>&copy; {year} Lawful AI. Daily AI intelligence with a legal edge.</p>
      </div>
    </div>
  </div>
</footer>
